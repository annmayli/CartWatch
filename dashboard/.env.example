# Copy to `.env.local` and tweak as needed. Vite only exposes vars prefixed with VITE_.

# Backend URL used by the dashboard.
VITE_API_BASE=http://localhost:4000

# Feature flags. Set to "true" to expose in-progress UI.
# Settings page toggles aren't wired up yet — leave disabled in production.
VITE_ENABLE_SETTINGS=false
